root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h,cpp,hpp}]
indent_style = space
indent_size = 4
max_line_length = 80

[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 88

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[*.{cmake,txt,toml,cfg,ini}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 4
shell_variant = bash

[*.{ps1,psm1}]
indent_style = space
indent_size = 4

[*.bat]
indent_style = tab
end_of_line = crlf

[Makefile]
indent_style = tab

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
