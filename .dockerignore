**/CMakeCache.txt
**/cmake_install.cmake
**/CMakeLists.txt.user

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes
.gitmodules

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyo
*.egg-info/
*.egg
*.dist-info/
*.whl
.pytest_cache/
.coverage
.tox/
.venv/
venv/
env/

